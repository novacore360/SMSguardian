<?xml version="1.0" encoding="utf-8"?>
<!--
    Block all cleartext traffic globally. HTTPS-only.
    Supabase and Ktor use TLS so no domain exceptions are needed.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
