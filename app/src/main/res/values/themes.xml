<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme for Compose. Using MaterialComponents ensures
         the AppCompat/Material bridge works correctly with Compose's MDC theme. -->
    <style name="Theme.SecureSMSGuardian" parent="Theme.AppCompat.DayNight.NoActionBar" />

    <style name="Theme.SecureSMSGuardian.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#1A1A2E</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_shield_notification</item>
        <item name="postSplashScreenTheme">@style/Theme.SecureSMSGuardian</item>
    </style>
</resources>
